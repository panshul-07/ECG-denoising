{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ECG Denoising: Quick (10s, 10 trials)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/novel_ecg_denoising.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--process-sec",
        "10",
        "--ceemdan-trials",
        "10",
        "--output-dir",
        "results"
      ]
    },
    {
      "name": "ECG Denoising: Standard (30s, 50 trials)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/novel_ecg_denoising.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--process-sec",
        "30",
        "--ceemdan-trials",
        "50",
        "--output-dir",
        "results"
      ]
    }
  ]
}
